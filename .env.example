APP_PORT=8085
APP_NAME=presence-service
APP_ENV=local
LOG_LEVEL=info
LOG_FORMAT=json

POSTGRES_DSN=postgres://<user>:<password>@localhost:5432/parkir_pintar?sslmode=disable

# gRPC address of the Billing Service (no scheme)
BILLING_SERVICE_URL=localhost:8084

# OpenTelemetry — leave empty to disable
OTEL_SERVICE_NAME=parkirpintar-presence
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL=60
OTEL_BLRP_SCHEDULE_DELAY=60
